{
  "name": "scoreporch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node server/index.js\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build && vite build --config vite.config.widget.js && mkdir -p dist/widget && cp dist-widget/scoreporch-widget.js dist/widget/",
    "build:app": "vite build",
    "build:widget": "vite build --config vite.config.widget.js",
    "preview": "vite preview",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@stripe/stripe-js": "^9.0.0",
    "@supabase/supabase-js": "^2.100.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "micro": "^10.0.1",
    "node-fetch": "^3.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "stripe": "^21.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "vite": "^5.0.0"
  }
}
